// ============================================================
// Prisma Schema — Sistema de Gestión de Gimnasio
// Stack: NestJS + Next.js + PostgreSQL + Docker + Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENTIDAD: Plan de Membresía (HU-03, HU-04)
// ============================================================
model PlanMembresia {
  id           Int      @id @default(autoincrement())
  nombre       String   @unique
  codigo       String   @unique
  duracionDias Int // Duración en días (30, 90, 365)
  precio       Decimal  @db.Decimal(10, 2)
  beneficios   String[] // Array JSON de beneficios
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  miembros         Miembro[]
  historialCambios PlanHistory[]

  @@map("planes_membresia")
}

// ============================================================
// ENTIDAD: Historial de cambios de Plan (HU-04)
// ============================================================
model PlanHistory {
  id                   Int      @id @default(autoincrement())
  planMembresiId       Int
  precioAnterior       Decimal  @db.Decimal(10, 2)
  precioNuevo          Decimal  @db.Decimal(10, 2)
  beneficiosAnteriores String[]
  beneficiosNuevos     String[]
  usuarioId            Int
  fechaCambio          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relaciones
  planMembresia PlanMembresia @relation(fields: [planMembresiId], references: [id], onDelete: Cascade)

  @@map("plan_history")
}

// ============================================================
// ENTIDAD: Miembros (HU-01, HU-02)
// ============================================================
model Miembro {
  id                 Int      @id @default(autoincrement())
  nombres            String
  apellidos          String
  documentoIdentidad String   @unique
  correoPersonal     String   @unique
  telefono           String?
  fechaNacimiento    DateTime
  planMembresiaId    Int // FK a plan (muchos a uno)
  fechaInicio        DateTime
  fechaVencimiento   DateTime
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relaciones
  planMembresia     PlanMembresia     @relation(fields: [planMembresiaId], references: [id], onDelete: Restrict)
  rutinas           Rutina[]
  medidasCorporales BodyMeasurement[]
  auditLog          MemberAuditLog[]

  @@map("miembros")
}

// ============================================================
// ENTIDAD: Audit Log de Miembros (HU-02)
// ============================================================
model MemberAuditLog {
  id            Int      @id @default(autoincrement())
  miembroId     Int
  usuarioId     Int
  cambios       String // JSON con campos modificados
  valorAnterior String? // JSON con valores anteriores
  valorNuevo    String? // JSON con valores nuevos
  fechaCambio   DateTime @default(now())
  createdAt     DateTime @default(now())

  // Relaciones
  miembro Miembro @relation(fields: [miembroId], references: [id], onDelete: Cascade)

  @@map("member_audit_log")
}

// ============================================================
// ENTIDAD: Entrenador (HU-05, HU-06)
// ============================================================
model Entrenador {
  id                  Int      @id @default(autoincrement())
  nombres             String
  apellidos           String
  documentoIdentidad  String   @unique
  correoInstitucional String   @unique
  telefono            String?
  especialidad        String // ej: Musculación, Cardio, Funcional
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relaciones
  disponibilidades TrainerAvailability[]
  rutinas          Rutina[]

  @@map("entrenadores")
}

// ============================================================
// ENTIDAD: Disponibilidad del Entrenador (HU-05, HU-06)
// ============================================================
model TrainerAvailability {
  id           Int      @id @default(autoincrement())
  entrenadorId Int
  diaSemana    Int // 0=Lunes, 1=Martes, ..., 6=Domingo
  horaInicio   String // Formato "HH:mm" (24h)
  horaFin      String // Formato "HH:mm" (24h)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  entrenador Entrenador @relation(fields: [entrenadorId], references: [id], onDelete: Cascade)

  @@unique([entrenadorId, diaSemana, horaInicio, horaFin])
  @@map("trainer_availability")
}

// ============================================================
// ENTIDAD: Rutina (HU-07, HU-08)
// ============================================================
model Rutina {
  id                Int      @id @default(autoincrement())
  nombre            String
  objetivo          String // ej: Pérdida de peso, Ganancia muscular
  miembroId         Int
  entrenadorId      Int
  diasEntrenamiento String[] // JSON array: ["Lunes", "Miércoles", "Viernes"]
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  miembro    Miembro           @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  entrenador Entrenador        @relation(fields: [entrenadorId], references: [id], onDelete: Restrict)
  ejercicios RutinaEjercicio[]
  historial  RoutineHistory[]

  @@unique([miembroId])
  @@map("rutinas")
}

// ============================================================
// ENTIDAD: Ejercicio (HU-07, HU-08)
// ============================================================
model Ejercicio {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  rutinas RutinaEjercicio[]

  @@map("ejercicios")
}

// ============================================================
// ENTIDAD: Rutina - Ejercicio (HU-07, HU-08)
// Tabla intermedia que vincula ejercicios a rutinas
// ============================================================
model RutinaEjercicio {
  id                Int      @id @default(autoincrement())
  rutinaId          Int
  ejercicioId       Int
  series            Int
  repeticiones      Int
  tiempoDescansoSeg Int // Tiempo en segundos
  orden             Int // Orden en que aparece el ejercicio
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  rutina    Rutina    @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  ejercicio Ejercicio @relation(fields: [ejercicioId], references: [id], onDelete: Restrict)

  @@unique([rutinaId, ejercicioId])
  @@map("rutina_ejercicios")
}

// ============================================================
// ENTIDAD: Historial de cambios de Rutina (HU-08)
// ============================================================
model RoutineHistory {
  id           Int      @id @default(autoincrement())
  rutinaId     Int
  entrenadorId Int?
  cambios      String // JSON con detalle de cambios
  version      Int // Número de versión
  createdAt    DateTime @default(now())

  // Relaciones
  rutina Rutina @relation(fields: [rutinaId], references: [id], onDelete: Cascade)

  @@map("routine_history")
}

// ============================================================
// ENTIDAD: Medidas Corporales (HU-09, HU-10)
// ============================================================
model BodyMeasurement {
  id              Int      @id @default(autoincrement())
  miembroId       Int
  entrenadorId    Int?
  peso            Decimal  @db.Decimal(5, 2) // kg
  talla           Decimal  @db.Decimal(5, 2) // cm
  porcentajeGrasa Decimal  @db.Decimal(5, 2) // %
  fechaMedicion   DateTime
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  miembro Miembro @relation(fields: [miembroId], references: [id], onDelete: Cascade)

  @@map("body_measurements")
}
