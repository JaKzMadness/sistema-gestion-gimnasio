generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Rol {
  ADMIN
  RECEPCIONISTA
  ENTRENADOR
  MIEMBRO
}

model Usuario {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  rol             Rol       @default(MIEMBRO)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditorias      MemberAuditLog[]
  cambiosPlanes   PlanHistory[]
  perfilMiembro   Miembro?
  perfilEntrenador Entrenador?

  @@map("usuarios")
}

model PlanMembresia {
  id              Int       @id @default(autoincrement())
  nombre          String    @unique
  codigo          String    @unique
  duracionDias    Int       // 30, 90, 365
  precio          Decimal   @db.Decimal(10, 2)
  beneficios      String[]  // JSON array
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relaciones
  miembros        Miembro[]
  historial       PlanHistory[]

  @@map("planes_membresia")
}

model PlanHistory {
  id                      Int       @id @default(autoincrement())
  planMembresiaId         Int
  precioAnterior          Decimal   @db.Decimal(10, 2)
  precioNuevo             Decimal   @db.Decimal(10, 2)
  beneficiosAnteriores    String[]  // JSON array
  beneficiosNuevos        String[]  // JSON array
  usuarioId               Int
  fechaCambio             DateTime  @default(now())
  createdAt               DateTime  @default(now())

  // Relaciones
  planMembresia           PlanMembresia @relation(fields: [planMembresiaId], references: [id], onDelete: Cascade)
  usuario                 Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@map("plan_history")
}

model Miembro {
  id                  Int       @id @default(autoincrement())
  usuarioId           Int?      @unique
  nombres             String
  apellidos           String
  documentoIdentidad  String    @unique
  correoPersonal      String    @unique
  telefono            String?
  fechaNacimiento     DateTime
  planMembresiaId     Int
  precioInscripcion   Decimal   @db.Decimal(10, 2) // Precio pagado al momento de inscripción
  fechaInicio         DateTime
  fechaVencimiento    DateTime
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relaciones
  usuario             Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  planMembresia       PlanMembresia    @relation(fields: [planMembresiaId], references: [id], onDelete: Restrict)
  rutinas             Rutina[]
  medidas             BodyMeasurement[]
  auditorias          MemberAuditLog[]

  @@map("miembros")
}

model MemberAuditLog {
  id                  Int       @id @default(autoincrement())
  miembroId           Int
  usuarioId           Int
  cambios             String    
  valorAnterior       String?   
  valorNuevo          String?   
  fechaCambio         DateTime  @default(now())
  createdAt           DateTime  @default(now())

  miembro             Miembro   @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  usuario             Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@map("member_audit_log")
}

model Entrenador {
  id                      Int       @id @default(autoincrement())
  usuarioId               Int?      @unique
  nombres                 String
  apellidos               String
  documentoIdentidad      String    @unique
  correoInstitucional     String    @unique
  telefono                String?
  especialidad            String    
  activo                  Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  usuario                 Usuario?              @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  disponibilidades        TrainerAvailability[]
  rutinas                 Rutina[]
  medicionesRealizadas    BodyMeasurement[]
  historialesRutina       RoutineHistory[]

  @@map("entrenadores")
}

model TrainerAvailability {
  id                  Int       @id @default(autoincrement())
  entrenadorId        Int
  diaSemana           Int       
  horaInicio          String    
  horaFin             String    
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  
  entrenador          Entrenador @relation(fields: [entrenadorId], references: [id], onDelete: Cascade)

 
  @@unique([entrenadorId, diaSemana, horaInicio, horaFin])
  @@map("trainer_availability")
}

model Rutina {
  id                  Int       @id @default(autoincrement())
  nombre              String
  objetivo            String    
  miembroId           Int       @unique 
  entrenadorId        Int
  diasEntrenamiento   String[]  
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  
  miembro             Miembro              @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  entrenador          Entrenador           @relation(fields: [entrenadorId], references: [id], onDelete: Restrict)
  ejercicios          RutinaEjercicio[]
  historial           RoutineHistory[]

  @@map("rutinas")
}

model Ejercicio {
  id                  Int       @id @default(autoincrement())
  nombre              String    @unique
  descripcion         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

 
  rutinas             RutinaEjercicio[]

  @@map("ejercicios")
}

model RutinaEjercicio {
  id                  Int       @id @default(autoincrement())
  rutinaId            Int
  ejercicioId         Int
  series              Int       
  repeticiones        Int       
  tiempoDescansoSeg   Int       
  orden               Int       
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

 
  rutina              Rutina    @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  ejercicio           Ejercicio @relation(fields: [ejercicioId], references: [id], onDelete: Restrict)

  
  @@unique([rutinaId, ejercicioId])
  @@map("rutina_ejercicios")
}

model RoutineHistory {
  id                  Int       @id @default(autoincrement())
  rutinaId            Int
  entrenadorId        Int?      
  cambios             String    
  version             Int       
  createdAt           DateTime  @default(now())

 
  rutina              Rutina    @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  entrenador          Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)

  @@map("routine_history")
}

model BodyMeasurement {
  id                  Int       @id @default(autoincrement())
  miembroId           Int
  entrenadorId        Int?      
  peso                Decimal   @db.Decimal(5, 2)     
  talla               Decimal   @db.Decimal(5, 2)     
  porcentajeGrasa     Decimal   @db.Decimal(5, 2)     
  fechaMedicion       DateTime  
  notas               String?   
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relaciones
  miembro             Miembro   @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  entrenador          Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)

  @@map("body_measurements")
}