// ============================================================
// Prisma Schema — Sistema de Gestión de Gimnasio (Versión Corregida)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  RECEPCIONISTA
  ENTRENADOR
  MIEMBRO
}

model Usuario {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String   
  rol             Rol      @default(MIEMBRO)
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditorias      MemberAuditLog[]
  cambiosPlanes   PlanHistory[]
  perfilMiembro   Miembro?
  perfilEntrenador Entrenador?

  @@map("usuarios")
}

model PlanMembresia {
  id              Int         @id @default(autoincrement())
  nombre          String      @unique
  codigo          String      @unique
  duracionDias    Int         
  precio          Decimal     @db.Decimal(10, 2)
  beneficios      String[]    
  activo          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  miembros        Miembro[]
  historial       PlanHistory[]

  @@map("planes_membresia")
}

model PlanHistory {
  id                  Int           @id @default(autoincrement())
  planMembresiaId     Int
  precioAnterior      Decimal       @db.Decimal(10, 2)
  precioNuevo         Decimal       @db.Decimal(10, 2)
  usuarioId           Int           
  fechaCambio         DateTime      @default(now())

  planMembresia       PlanMembresia @relation(fields: [planMembresiaId], references: [id])
  usuario             Usuario       @relation(fields: [usuarioId], references: [id])

  @@map("plan_history")
}

model Miembro {
  id                  Int         @id @default(autoincrement())
  usuarioId           Int?        @unique 
  nombres             String     
  apellidos           String
  documentoIdentidad  String      @unique
  correoPersonal      String      @unique
  telefono            String?
  fechaNacimiento     DateTime   
  planMembresiaId     Int         
  precioInscripcion   Decimal     @db.Decimal(10, 2) 
  fechaInicio         DateTime   
  fechaVencimiento    DateTime   
  activo              Boolean     @default(true)
  createdAt           DateTime    @default(now())

  usuario             Usuario?    @relation(fields: [usuarioId], references: [id])
  planMembresia       PlanMembresia @relation(fields: [planMembresiaId], references: [id])
  rutinas             Rutina[]
  medidas             BodyMeasurement[]
  auditorias          MemberAuditLog[]

  @@map("miembros")
}

model MemberAuditLog {
  id                  Int         @id @default(autoincrement())
  miembroId           Int        
  usuarioId           Int         
  cambios             String      
  fechaCambio         DateTime    @default(now())

  miembro             Miembro     @relation(fields: [miembroId], references: [id])
  usuario             Usuario     @relation(fields: [usuarioId], references: [id])

  @@map("member_audit_log")
}

model Entrenador {
  id                  Int         @id @default(autoincrement())
  usuarioId           Int?        @unique
  nombres             String     
  apellidos           String
  documentoIdentidad  String      @unique
  especialidad        String     
  
  usuario             Usuario?    @relation(fields: [usuarioId], references: [id])
  disponibilidades    TrainerAvailability[]
  rutinas             Rutina[]
  medicionesRealizadas BodyMeasurement[]

  @@map("entrenadores")
}

model TrainerAvailability {
  id                  Int         @id @default(autoincrement())
  entrenadorId        Int        
  diaSemana           Int         
  horaInicio          String      
  horaFin             String      

  entrenador          Entrenador  @relation(fields: [entrenadorId], references: [id])

  @@map("trainer_availability")
}

model Rutina {
  id                  Int         @id @default(autoincrement())
  nombre              String     
  objetivo            String      
  miembroId           Int        
  entrenadorId        Int         
  activo              Boolean     @default(true)

  miembro             Miembro     @relation(fields: [miembroId], references: [id])
  entrenador          Entrenador  @relation(fields: [entrenadorId], references: [id])
  ejercicios          RutinaEjercicio[]
  historial           RoutineHistory[]

  @@map("rutinas")
}

model RutinaEjercicio {
  id                  Int         @id @default(autoincrement())
  rutinaId            Int        
  ejercicioId         Int
  series              Int
  repeticiones        Int
  tiempoDescansoSeg   Int         
  orden               Int        

  rutina              Rutina      @relation(fields: [rutinaId], references: [id])
  ejercicio           Ejercicio   @relation(fields: [ejercicioId], references: [id])

  @@map("rutina_ejercicios")
}

model Ejercicio {
  id                  Int         @id @default(autoincrement())
  nombre              String      @unique
  rutinas             RutinaEjercicio[]

  @@map("ejercicios")
}

model RoutineHistory {
  id                  Int         @id @default(autoincrement())
  rutinaId            Int        
  cambios             String      
  version             Int         
  createdAt           DateTime    @default(now())

  rutina              Rutina      @relation(fields: [rutinaId], references: [id])

  @@map("routine_history")
}

model BodyMeasurement {
  id                  Int         @id @default(autoincrement())
  miembroId           Int        
  entrenadorId        Int?        
  peso                Decimal     @db.Decimal(5, 2)
  talla               Decimal     @db.Decimal(5, 2)
  porcentajeGrasa     Decimal     @db.Decimal(5, 2)
  fechaMedicion       DateTime   

  miembro             Miembro     @relation(fields: [miembroId], references: [id])
  entrenador          Entrenador? @relation(fields: [entrenadorId], references: [id])

  @@map("body_measurements")
}